// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Brand {
  id                String       @id @default(uuid())
  brand_name        String
  owner_name        String
  email             String       @unique
  phone             String
  password_hash     String
  orders_per_day    String?
  created_at        DateTime     @default(now())

  orders            Order[]
  integrations      Integration?
  aiConfig          AIBotConfig?
  aiOrders          AIOrder[]
}

model Order {
  id                String       @id @default(uuid())
  brand_id          String
  order_number      String
  customer_name     String
  phone             String
  product_name      String
  product_color     String?
  price             Float
  address           String
  source_platform   String
  status            String       @default("pending") // pending, confirmed, cancelled
  created_at        DateTime     @default(now())
  confirmed_at      DateTime?

  brand             Brand        @relation(fields: [brand_id], references: [id])
  messages          Message[]
}

model Message {
  id                String       @id @default(uuid())
  order_id          String
  phone             String
  message           String
  message_type      String       // system, customer
  created_at        DateTime     @default(now())

  order             Order        @relation(fields: [order_id], references: [id])
}

model Integration {
  id                           String       @id @default(uuid())
  brand_id                     String       @unique
  shopify_api_key              String?
  wordpress_webhook            String?
  custom_api_key               String?      @unique
  whatsapp_connected           Boolean      @default(false)
  
  meta_app_id                  String?
  meta_phone_number_id         String?
  meta_access_token            String?
  meta_business_account_id     String?
  meta_template_name           String?

  brand                        Brand        @relation(fields: [brand_id], references: [id])
}

// AI Bot Configuration
model AIBotConfig {
  id                    String       @id @default(uuid())
  brand_id              String       @unique
  
  // OpenAI Config
  openai_api_key        String?
  ai_model              String       @default("gpt-4o-mini")
  
  // WhatsApp Config (Meta Cloud API)
  wa_phone_number_id    String?
  wa_access_token       String?
  wa_verify_token       String?      @default("ai_bot_secret")
  
  // Bot Behavior
  bot_enabled           Boolean      @default(false)
  ai_personality        String?      @default("friendly")
  custom_prompt         String?
  
  // Product Info
  product_name          String?
  product_description   String?
  product_price         Float?
  product_min_price     Float?       // Minimum price for negotiation
  currency              String?      @default("PKR")
  
  created_at            DateTime     @default(now())
  updated_at            DateTime     @updatedAt

  brand                 Brand        @relation(fields: [brand_id], references: [id])
  productImages         ProductImage[]
  conversations         AIConversation[]
}

// Product Images for AI to send
model ProductImage {
  id              String       @id @default(uuid())
  bot_config_id   String
  image_url       String       // stored path/URL
  image_name      String?
  display_order   Int          @default(0)
  created_at      DateTime     @default(now())

  botConfig       AIBotConfig  @relation(fields: [bot_config_id], references: [id])
}

// AI Conversation sessions
model AIConversation {
  id              String       @id @default(uuid())
  bot_config_id   String
  customer_phone  String
  customer_name   String?
  city            String?
  address         String?
  stage           String       @default("greeting") // greeting, name, city, address, product_info, negotiation, confirmed
  messages        String       @default("[]") // JSON array of {role, content, timestamp}
  created_at      DateTime     @default(now())
  updated_at      DateTime     @updatedAt

  botConfig       AIBotConfig  @relation(fields: [bot_config_id], references: [id])
  aiOrder         AIOrder?
}

// WhatsApp AI Orders
model AIOrder {
  id                  String       @id @default(uuid())
  brand_id            String
  conversation_id     String?      @unique
  
  customer_name       String
  customer_phone      String
  city                String?
  address             String?
  
  product_name        String?
  product_image_url   String?
  final_price         Float?
  
  status              String       @default("confirmed") // confirmed, cancelled
  confirmation_sent   Boolean      @default(false)
  confirmation_sent_at DateTime?
  
  created_at          DateTime     @default(now())

  brand               Brand        @relation(fields: [brand_id], references: [id])
  conversation        AIConversation? @relation(fields: [conversation_id], references: [id])
}
